class Solution {
public:
    int thirdMax(vector<int>& nums) {
        sort(nums.begin(),nums.end());
        reverse(nums.begin(),nums.end());
        int count = 0;
        int n=nums.size();
        if(n>=3){
            for(int i=1;i<n;i++){
                if(nums[i]==nums[i-1]){
                    continue;
                }
                else{
                    count++;
                }
                if(count==2){//at count 0 we get 1st max 
                    return nums[i];
                }
            }
        }
        return nums[0];
    }
};
